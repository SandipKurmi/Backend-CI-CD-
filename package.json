    "repository": {
        "type": "git",
        "url": "git+https://github.com/SandipKurmi/mernspace-c-auth-service.git"
    },
    "author": "Sandip <sandipkurmi0@gmail.com>",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/SandipKurmi/mernspace-c-auth-service/issues"
    },
    "homepage": "https://github.com/SandipKurmi/mernspace-c-auth-service#readme",
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@types/express": "^5.0.0",
        "@types/http-errors": "^2.0.4",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.5",
        "@types/supertest": "^6.0.2",
        "@types/winston": "^2.4.4",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^9.1.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^15.3.0",
        "nodemon": "^3.1.9",
        "prettier": "3.4.2",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.19.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "http-errors": "^2.0.0",
        "winston": "^3.17.0"
